@{
    ViewData["Title"] = "Reports";
    var topQueries = ViewBag.TopQueries as IReadOnlyList<(string Query, int Count)> ?? new List<(string, int)>();
    var topResults = ViewBag.TopResults as IReadOnlyList<(string ComicId, int Count)> ?? new List<(string, int)>();
    var frequentComics = ViewBag.FrequentComics as IEnumerable<string> ?? new List<string>();
}

<h1>Reports Dashboard</h1>

<h3>Top 10 Search Queries</h3>
@if (topQueries.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Query</th>
                <th>Count</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in topQueries)
            {
                <tr>
                    <td>@item.Query</td>
                    <td>@item.Count</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No search queries recorded yet.</p>
}

<h3>Top 10 Most Returned Comics</h3>
@if (topResults.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Comic ID</th>
                <th>Appearances</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in topResults)
            {
                <tr>
                    <td>@item.ComicId</td>
                    <td>@item.Count</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No results data recorded yet.</p>
}

<h3>Comics Appearing in More Than 100 Searches</h3>
@if (frequentComics.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Comic ID</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comic in frequentComics)
            {
                <tr>
                    <td>@comic</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No comics have appeared in more than 100 searches yet.</p>
}

<a asp-controller="Comics" asp-action="Index" class="btn btn-secondary mt-3">Back to Comics</a>
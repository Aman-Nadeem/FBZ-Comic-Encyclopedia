@model IEnumerable<IGrouping<int?, ComicApp.Core.Models.Comic>>

@{
    ViewData["Title"] = "Grouped by Year";
}

<h1>Comics Grouped by Year</h1>

<a asp-action="Index">Back to Comics</a>

@foreach (var group in Model)
{
    <h3>@group.Key</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Genres</th>
                <th>Languages</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comic in group)
            {
                <tr>
                    <td>@comic.Title</td>
                    <td>@string.Join(", ", comic.Genres)</td>
                    <td>@string.Join(", ", comic.Languages)</td>
                </tr>
            }
        </tbody>
    </table>
}


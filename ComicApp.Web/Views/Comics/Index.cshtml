@model IEnumerable<ComicApp.Core.Models.Comic>

@{
    ViewData["Title"] = "Comics";
    var comics = Model ?? Enumerable.Empty<ComicApp.Core.Models.Comic>();

    var role = Context.Session.GetString("Role");
    var username = Context.Session.GetString("Username");

    var flaggedIds = ViewBag.FlaggedIds as List<string> ?? new List<string>();
}

<h1>Comics</h1>

@if (role == "Staff")
{
    <a asp-controller="Comics"
       asp-action="Reports"
       class="btn btn-info mb-3">
        View Reports
    </a>
}

@if (!string.IsNullOrEmpty(username))
{
    <a asp-controller="Comics"
       asp-action="SavedSearches"
       class="btn btn-success mb-3">
        Saved Searches
    </a>
}

<!-- Search -->
<form asp-controller="Comics" asp-action="Search" method="post" class="mb-3">
    <input type="text" name="title" placeholder="Search by title..." />
    <button type="submit">Search</button>
    <a asp-controller="Comics" asp-action="Index" class="btn btn-secondary">Reset</a>
</form>

<!-- Advanced Search -->
<h3>Advanced Search</h3>
<form asp-controller="Comics" asp-action="AdvancedSearch" method="post" class="mb-3">
    <input type="text" name="title" placeholder="Title" />
    <input type="text" name="author" placeholder="Author" />
    <input type="number" name="year" placeholder="Year" />
    <input type="text" name="genre" placeholder="Genre" />
    <input type="text" name="language" placeholder="Language" />
    <input type="text" name="nameType" placeholder="Name Type" />
    <button type="submit">Advanced Search</button>
</form>

<!-- Genre Filter -->
<form asp-controller="Comics" asp-action="FilterByGenre" method="post" class="mb-3">
    <select name="genre">
        <option value="Fantasy">Fantasy</option>
        <option value="Horror">Horror</option>
        <option value="Science Fiction">Science Fiction</option>
    </select>
    <button type="submit">Filter</button>
</form>

<!-- Sorting -->
<form asp-controller="Comics" asp-action="Sort" method="post" class="mb-3">
    <button name="order" value="asc" type="submit">Sort A-Z</button>
    <button name="order" value="desc" type="submit">Sort Z-A</button>
</form>

<!-- Grouping -->
<form asp-controller="Comics" asp-action="GroupByAuthor" method="post" class="mb-3">
    <button type="submit">Group by Author</button>
</form>

<form asp-controller="Comics" asp-action="GroupByYear" method="post" class="mb-3">
    <button type="submit">Group by Year</button>
</form>

@if (Context.Request.Method == "POST")
{
    <p>@comics.Count() comics found</p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Year</th>
            <th>Genres</th>
            <th>Languages</th>
            <th>Creators</th>
            @if (!string.IsNullOrEmpty(username))
            {
                <th>Save</th>
            }
            @if (role == "Staff")
            {
                <th>Flag</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var comic in comics)
        {
            <tr>
                <td>
                    @comic.Title
                    @if (flaggedIds.Contains(comic.BlRecordId))
                    {
                        <span class="badge bg-danger ms-2">FLAGGED</span>
                    }
                </td>
                <td>@comic.PublicationYear</td>
                <td>@string.Join(", ", comic.Genres ?? new List<string>())</td>
                <td>@string.Join(", ", comic.Languages ?? new List<string>())</td>
                <td>
                    @string.Join(", ",
                             (comic.Creators ?? new List<ComicApp.Core.Models.Creator>())
                             .Select(cr => $"{cr.Name} ({cr.Role})"))
                </td>
                @if (!string.IsNullOrEmpty(username))
                {
                    <td>
                        <form asp-controller="Comics" asp-action="SaveComic" method="post">
                            <input type="hidden" name="id" value="@comic.BlRecordId" />
                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                        </form>
                    </td>
                }
                @if (role == "Staff")
                {
                    <td>
                        <form asp-controller="Flag" asp-action="Flag" method="post">
                            <input type="hidden" name="comicId" value="@comic.BlRecordId" />
                            <button type="submit" class="btn btn-sm btn-danger">Flag</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="mt-3">
    <p>Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalComics total comics)</p>
    <div class="btn-group">
        @if (ViewBag.CurrentPage > 1)
        {
            <a asp-controller="Comics"
               asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage - 1)"
               class="btn btn-secondary">
                Previous
            </a>
        }
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a asp-controller="Comics"
               asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage + 1)"
               class="btn btn-secondary">
                Next
            </a>
        }
    </div>
</div>
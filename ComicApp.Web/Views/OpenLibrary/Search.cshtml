@model List<ComicApp.Core.Services.OpenLibraryBook>

@{
    ViewData["Title"] = "Open Library Search";
}

<h2>Open Library Search</h2>

<form method="get" asp-action="Search" asp-controller="OpenLibrary">
    <div class="input-group mb-3">
        <input type="text" name="query" value="@ViewBag.Query" class="form-control" placeholder="Search Open Library..." />
        <button class="btn btn-primary" type="submit">Search</button>
    </div>
</form>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (item.CoverUrl != null)
                    {
                        <img src="@item.CoverUrl" class="card-img-top" alt="@item.Title" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>
                        @if (item.Authors.Any())
                        {
                            <p class="card-text"><strong>Authors:</strong> @string.Join(", ", item.Authors)</p>
                        }
                        @if (item.FirstPublishYear.HasValue)
                        {
                            <p class="card-text"><strong>First Published:</strong> @item.FirstPublishYear</p>
                        }
                        @if (item.OpenLibraryUrl != null)
                        {
                            <a href="@item.OpenLibraryUrl" target="_blank" class="btn btn-sm btn-outline-secondary">View on Open Library</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (ViewBag.Query != null)
{
    <p>No results found for "@ViewBag.Query".</p>
}